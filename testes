        "\n",
        "# --- New Decoder Classes (without Luong Attention, Supporting Stacked) ---\n",
        "\n",
        "class GRUDecoderNoAttn(nn.Module):\n",
        "    def __init__(self, vocab_size, emb_size, hidden_size, num_layers=1):\n",
