        "        Retorna:\n",
        "          context: (B, 1, H)\n",
        "          attn_weights: (B, 1, S)\n",
        "        \"\"\"\n",
        "\n",
        "        # score = h_t · h_s^T\n",
        "        # (B, 1, H) x (B, H, S) -> (B, 1, S)\n",
        "        attn_scores = torch.bmm(decoder_hidden, encoder_outputs.transpose(1, 2))\n",
        "\n",
        "        attn_weights = F.softmax(attn_scores, dim=-1)  # normaliza nos steps da source\n",
        "\n",
        "        # context = soma ponderada\n",
        "        # (B, 1, S) x (B, S, H) -> (B, 1, H)\n",
        "        context = torch.bmm(attn_weights, encoder_outputs)\n",
        "\n",
        "        return context, attn_weights\n",
        "\n",
        "# --- New Encoder Classes (Supporting Stacked and Bidirectional) ---\n",
        "\n",
        "class GRUEncoderNew(nn.Module):\n",
        "    def __init__(self, vocab_size, emb_size, hidden_size, num_layers=1, bidirectional=False):\n",
