        "\n",
        "# --- Generic Seq2Seq Class to combine any Encoder and Decoder ---\n",
        "class Seq2SeqNew(nn.Module):\n",
        "    def __init__(self, encoder, decoder):\n",
        "        super().__init__()\n",
        "        self.encoder = encoder\n",
        "        self.decoder = decoder\n",
        "\n",
        "        # Ensure hidden_size consistency (assuming they are set to be equal for this problem)\n",
        "        if self.encoder.hidden_size != self.decoder.hidden_size:\n",
        "            raise ValueError(\"Encoder and decoder hidden sizes must be equal.\")\n",
        "\n",
        "    def _adapt_encoder_hidden_to_decoder(self, h_encoder, batch_size):\n",
        "        # Determine if the encoder's hidden state is an LSTM tuple (h_n, c_n)\n",
        "        is_encoder_lstm = isinstance(h_encoder, tuple)\n",
        "        num_directions_encoder = 2 if self.encoder.bidirectional else 1\n",
        "\n",
        "        if is_encoder_lstm:\n",
        "            h_n_encoder, c_n_encoder = h_encoder\n",
        "        else:\n",
        "            h_n_encoder = h_encoder\n",
        "            c_n_encoder = None # Only relevant if encoder was LSTM\n",
        "\n",
        "        # Reshape h_n_encoder to (num_layers_encoder, num_directions, batch_size, hidden_size)\n",
        "        # Then sum over directions to get (num_layers_encoder, batch_size, hidden_size) for a unidirectional view\n",
        "        h_n_adapted = h_n_encoder.view(\n",
        "            self.encoder.num_layers, num_directions_encoder, batch_size, self.encoder.hidden_size\n",
        "        ).sum(dim=1)\n",
        "\n",
        "        # Adapt num_layers from encoder to decoder for h_decoder\n",
        "        num_layers_decoder = self.decoder.num_layers\n",
        "        num_layers_encoder_effective = self.encoder.num_layers\n",
        "\n",
        "        if num_layers_encoder_effective >= num_layers_decoder:\n",
        "            h_decoder_state = h_n_adapted[-num_layers_decoder:, :, :]\n",
        "        else:\n",
        "            h_decoder_state = torch.cat([\n",
        "                h_n_adapted,\n",
        "                torch.zeros(num_layers_decoder - num_layers_encoder_effective, batch_size, self.decoder.hidden_size, device=h_n_adapted.device)\n",
        "            ], dim=0)\n",
        "\n",
        "        # Now, check if the DECODER is an LSTM and needs a cell state\n",
        "        is_decoder_lstm = isinstance(self.decoder, (LSTMDecoderNew, LSTMDecoderNoAttn)) # Include both LSTM decoder types\n",
        "\n",
        "        if is_decoder_lstm:\n",
        "            if is_encoder_lstm:\n",
        "                # Encoder was also LSTM, adapt its c_n_encoder\n",
        "                c_n_adapted = c_n_encoder.view(\n",
        "                    self.encoder.num_layers, num_directions_encoder, batch_size, self.encoder.hidden_size\n",
        "                ).sum(dim=1)\n",
        "\n",
        "                if num_layers_encoder_effective >= num_layers_decoder:\n",
        "                    c_decoder_state = c_n_adapted[-num_layers_decoder:, :, :]\n",
        "                else:\n",
        "                    c_decoder_state = torch.cat([\n",
        "                        c_n_adapted,\n",
        "                        torch.zeros(num_layers_decoder - num_layers_encoder_effective, batch_size, self.decoder.hidden_size, device=c_n_adapted.device)\n",
        "                    ], dim=0)\n",
        "            else:\n",
        "                # Encoder was GRU/RNN, initialize decoder's cell state with zeros\n",
        "                c_decoder_state = torch.zeros(num_layers_decoder, batch_size, self.decoder.hidden_size, device=h_n_adapted.device)\n",
        "\n",
        "            return (h_decoder_state, c_decoder_state)\n",
        "        else:\n",
        "            # Decoder is GRU or RNN, only needs a hidden state tensor\n",
        "            return h_decoder_state\n",
        "\n",
        "\n",
        "    def forward(self, src, tgt):\n",
        "        batch_size = src.size(0)\n",
        "        encoder_outputs, h_encoder = self.encoder(src)\n",
        "\n",
        "        # Adapt encoder_outputs if encoder is bidirectional\n",
        "        if self.encoder.bidirectional:\n",
        "            # encoder_outputs: (B, S, D*H) where D=2 for bidirectional\n",
        "            # We need to reshape to (B, S, H) by summing the forward and backward components\n",
        "            encoder_outputs = encoder_outputs.view(\n",
        "                batch_size, -1, 2, self.encoder.hidden_size\n",
        "            ).sum(dim=2) # Sum over the direction dimension (dim=2 after view)\n",
        "            # Now encoder_outputs is (B, S, H)\n",
        "\n",
        "        # Adapt h_encoder to decoder's expected hidden state format\n",
        "        h_decoder = self._adapt_encoder_hidden_to_decoder(h_encoder, batch_size)\n",
        "\n",
        "        logits, _ = self.decoder(tgt[:, :-1], h_decoder, encoder_outputs)\n",
        "        return logits\n",
        "\n",
        "# --- Modified decode_step function to handle all RNN types and stacked hidden states ---\n",
        "def decode_step_new(decoder, token, h, encoder_outputs):\n",
        "    # h can be a tensor (L, B, H) or a tuple of two tensors (L, B, H)\n",
        "    logits, h_new = decoder(token, h, encoder_outputs)  # (B,1,V)\n",
        "    next_token = logits[:, -1, :].argmax(-1, keepdim=True)  # (B,1)\n",
        "    return next_token, h_new\n",
        "\n",
        "# --- Modified predict function to use the new classes and decode_step ---\n",
        "def predict_new(model, seq, max_len):\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        batch_size = 1 # For single sequence prediction\n",
        "        # Encode input sequence\n",
        "        src = pad(encode(seq)).unsqueeze(0).to(device, dtype=torch.long)\n",
        "\n",
        "        # Get encoder outputs and initial hidden state (can be tensor or tuple)\n",
        "        encoder_outputs, h_encoder = model.encoder(src)\n",
        "\n",
        "        # Adapt encoder_outputs if encoder is bidirectional\n",
        "        if model.encoder.bidirectional:\n",
        "            encoder_outputs = encoder_outputs.view(\n",
        "                batch_size, -1, 2, model.encoder.hidden_size\n",
        "            ).sum(dim=2)\n",
        "\n",
        "        # Adapt h for the decoder's prediction loop\n",
        "        h_initial = model._adapt_encoder_hidden_to_decoder(h_encoder, batch_size)\n",
        "\n",
        "        # Initial decoder token (e.g., space or <sos>)\n",
        "        token = torch.tensor([[vocab[' ']]], dtype=torch.long, device=device)\n",
        "\n",
        "        inverted_seq_tokens = []\n",
        "        current_h = h_initial\n",
        "        for _ in range(max_len):\n",
        "            token, current_h = decode_step_new(model.decoder, token, current_h, encoder_outputs)\n",
        "            inverted_seq_tokens.append(token.item())\n",
        "\n",
        "        return decode(inverted_seq_tokens)\n",
        "\n",
        "# --- Training function ---\n",
        "def train_model(model_instance, train_dl, loss_fn, opt, epochs=10):\n",
        "    enc_name = type(model_instance.encoder).__name__.replace('EncoderNew', '')\n",
        "    dec_name = type(model_instance.decoder).__name__.replace('DecoderNew', '').replace('DecoderNoAttn', '')\n",
        "\n",
        "    # Determine if the decoder uses attention\n",
        "    has_attention = hasattr(model_instance.decoder, 'attn')\n",
        "    model_combo_name = f\"{enc_name}-{dec_name} (Attn: {has_attention}, Enc L:{model_instance.encoder.num_layers}, Dec L:{model_instance.decoder.num_layers}, Enc Bi:{model_instance.encoder.bidirectional})\";\n",
        "    print(f\"Iniciando treinamento para o modelo {model_combo_name}...\")\n",
        "    history = [] # To store loss and char error\n",
        "    for epoch in range(epochs):\n",
        "        model_instance.train()\n",
        "        total_loss = 0\n",
        "        for xb, yb in train_dl:\n",
        "            xb, yb = xb.to(device, dtype=torch.long), yb.to(device, dtype=torch.long)\n",
        "            opt.zero_grad()\n",
        "            logits = model_instance(xb, yb)\n",
        "            # Reshape yb for CrossEntropyLoss, ignoring the first token of target (teacher forcing start token)\n",
        "            loss = loss_fn(logits.reshape(-1, vocab_size), yb[:, 1:].reshape(-1))\n",
        "            loss.backward()\n",
        "            opt.step()\n",
        "            total_loss += loss.item()\n",
        "\n",
        "        # Calculate Character Error Rate for the epoch\n",
        "        epoch_char_error_count = 0\n",
        "        total_chars_compared = 0\n",
        "\n",
        "        model_instance.eval() # Switch to evaluation mode for inference, disables dropout etc.\n",
        "        with torch.no_grad(): # Disable gradient calculation for this metric\n",
        "            for xb_eval, yb_eval in train_dl: # Use the training DataLoader for consistency\n",
        "                xb_eval = xb_eval.to(device, dtype=torch.long)\n",
        "                batch_size_eval = xb_eval.size(0)\n",
        "\n",
        "                # Get encoder outputs and initial hidden state (can be tensor or tuple)\n",
        "                encoder_outputs_eval, h_encoder_eval = model_instance.encoder(xb_eval)\n",
        "\n",
        "                # Adapt encoder_outputs_eval if encoder is bidirectional\n",
        "                if model_instance.encoder.bidirectional:\n",
        "                    encoder_outputs_eval = encoder_outputs_eval.view(\n",
        "                        batch_size_eval, -1, 2, model_instance.encoder.hidden_size\n",
        "                    ).sum(dim=2)\n",
        "\n",
        "                # Adapt h_encoder_eval for the decoder's prediction loop\n",
        "                h_initial_eval = model_instance._adapt_encoder_hidden_to_decoder(h_encoder_eval, batch_size_eval)\n",
        "\n",
        "                # Initial decoder token (e.g., space or <sos>) for the batch\n",
        "                token_eval = torch.tensor([[vocab[' ']]] * batch_size_eval, dtype=torch.long, device=device) # (B, 1)\n",
        "\n",
        "                predicted_decoded_tokens_batch = []\n",
        "                current_h_eval = h_initial_eval\n",
        "\n",
        "                for _ in range(max_len): # max_len is defined globally (5)\n",
        "                    next_token_eval, current_h_eval = decode_step_new(model_instance.decoder, token_eval, current_h_eval, encoder_outputs_eval)\n",
        "                    predicted_decoded_tokens_batch.append(next_token_eval)\n",
        "                    token_eval = next_token_eval # Update token for next step\n",
        "\n",
        "                # Concatenate to get batch of predicted sequences (B, max_len)\n",
        "                predicted_decoded_tokens_batch = torch.cat(predicted_decoded_tokens_batch, dim=1)\n",
