        "        self.fc = nn.Linear(hidden_size, vocab_size) # Linear layer takes only hidden_size\n",
        "\n",
        "    def forward(self, x, h, encoder_outputs=None): # encoder_outputs is ignored\n",
        "        x = self.embed(x)\n",
        "        outputs = []\n",
