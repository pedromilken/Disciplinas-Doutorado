        "# --- N-gram Analysis ---\n",
        "def get_ngrams(sequence, n):\n",
        "    \"\"\"Generates n-grams from a sequence.\"\"\"\n",
        "    if not isinstance(sequence, str):\n",
        "        sequence = str(sequence)\n",
        "    return set(tuple(sequence[i:i+n]) for i in range(len(sequence) - n + 1))\n",
        "\n",
        "def n_gram_jaccard_similarity(seq1, seq2, n=1):\n",
        "    \"\"\"Calculates Jaccard similarity based on n-grams.\"\"\"\n",
        "    ngrams1 = get_ngrams(seq1, n)\n",
        "    ngrams2 = get_ngrams(seq2, n)\n",
        "    if not ngrams1 and not ngrams2: # Handle empty sequences gracefully\n",
        "        return 1.0\n",
        "    intersection = len(ngrams1.intersection(ngrams2))\n",
        "    union = len(ngrams1.union(ngrams2))\n",
        "    return intersection / union if union != 0 else 0.0\n",
        "\n",
        "# --- Levenshtein Distance (Edit Distance) ---\n",
        "def calculate_levenshtein_distance(seq1, seq2):\n",
        "    \"\"\"Calculates Levenshtein distance between two sequences.\"\"\"\n",
        "    return editdistance.eval(seq1, seq2)\n",
