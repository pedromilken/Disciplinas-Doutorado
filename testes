        "\n",
        "# --- New Decoder Classes (with Luong Attention, Supporting Stacked) ---\n",
        "\n",
        "class GRUDecoderNew(nn.Module):\n",
        "    def __init__(self, vocab_size, emb_size, hidden_size, num_layers=1):\n",
        "        super().__init__()\n",
        "        self.hidden_size = hidden_size\n",
        "        self.num_layers = num_layers\n",
        "\n",
        "        self.embed = nn.Embedding(vocab_size, emb_size)\n",
        "        self.gru = nn.GRU(emb_size, hidden_size, num_layers=num_layers, batch_first=True) # Decoders are typically unidirectional\n",
        "        self.attn = LuongAttention() # Use the previously defined LuongAttention\n",
        "        # Attention combines decoder_output (1*H) and context (1*H) -> 2*H\n",
        "        self.fc = nn.Linear(hidden_size * 2, vocab_size)\n",
        "\n",
        "    def forward(self, x, h, encoder_outputs): # h is (L, B, H)\n",
        "        x = self.embed(x) # (B, T, E)\n",
        "        outputs = []\n",
        "        # hidden: (L, B, H)\n",
        "        # encoder_outputs: (B, S, D*H)\n",
        "\n",
        "        seq_len = x.size(1)\n",
        "        current_h = h # Decoder's initial hidden state for all layers\n",
        "\n",
        "        for t in range(seq_len):\n",
        "            inp = x[:, t:t+1]  # (B, 1, E)\n",
        "            out_t, current_h = self.gru(inp, current_h)   # out_t: (B, 1, H), current_h: (L, B, H)\n",
        "            # out_t is the output of the *last* GRU layer\n",
        "\n",
        "            # Attention expects (B, 1, H) for decoder_hidden\n",
        "            context, attn_w = self.attn(out_t, encoder_outputs)\n",
        "\n",
        "            # combined: (B, 1, 2*H)\n",
        "            combined = torch.cat([out_t, context], dim=-1)\n",
        "            logits = self.fc(combined)  # (B, 1, V)\n",
        "            outputs.append(logits)\n",
        "\n",
        "        outputs = torch.cat(outputs, dim=1)  # (B, T, V)\n",
        "        return outputs, current_h\n",
        "\n",
        "class LSTMDecoderNew(nn.Module):\n",
        "    def __init__(self, vocab_size, emb_size, hidden_size, num_layers=1):\n",
        "        super().__init__()\n",
        "        self.hidden_size = hidden_size\n",
        "        self.num_layers = num_layers\n",
        "\n",
        "        self.embed = nn.Embedding(vocab_size, emb_size)\n",
        "        self.lstm = nn.LSTM(emb_size, hidden_size, num_layers=num_layers, batch_first=True)\n",
        "        self.attn = LuongAttention()\n",
        "        self.fc = nn.Linear(hidden_size * 2, vocab_size)\n",
        "\n",
        "    def forward(self, x, h, encoder_outputs): # h is a tuple (h_n, c_n) where each is (L, B, H)\n",
        "        x = self.embed(x)\n",
        "        outputs = []\n",
        "        seq_len = x.size(1)\n",
        "        current_h_n, current_c_n = h # LSTM hidden state is a tuple (h_n, c_n)\n",
        "\n",
        "        for t in range(seq_len):\n",
        "            inp = x[:, t:t+1]\n",
        "            out_t, (current_h_n, current_c_n) = self.lstm(inp, (current_h_n, current_c_n)) # out_t: (B, 1, H)\n",
        "            context, attn_w = self.attn(out_t, encoder_outputs)\n",
        "            combined = torch.cat([out_t, context], dim=-1)\n",
        "            logits = self.fc(combined)\n",
        "            outputs.append(logits)\n",
        "\n",
        "        outputs = torch.cat(outputs, dim=1)  # (B, T, V)\n",
        "        return outputs, (current_h_n, current_c_n)\n",
        "\n",
        "class RNNDecoderNew(nn.Module):\n",
        "    def __init__(self, vocab_size, emb_size, hidden_size, num_layers=1):\n",
        "        super().__init__()\n",
        "        self.hidden_size = hidden_size\n",
        "        self.num_layers = num_layers\n",
        "\n",
